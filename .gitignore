# Runtime data — never commit
infra/data/
infra/.env
infra/litellm/.env.llm
infra/litellm/.env.cost
infra/docker-compose.override.yml
infra/victoriametrics/scrape.yml

# Ad-hoc session scripts under plans/reports/ (deploy/debug throwaways).
# .md reports/audits stay tracked as design records. If a .sh proves
# reusable, promote it to infra/scripts/ instead of keeping here.
plans/*
plans/reports/*.sh

# Backups & dumps — chứa data user / hashed passwords / secrets snapshot.
# 2026-07-13: postgres-legacy-*.sql (28KB) dumped vào backups/ khi decom PG.
# KHÔNG commit — nếu cần archive, upload offsite (S3/1Password/keepass).
# Scope root-only để infra/backup/ (age public key + README) vẫn được commit.
/backup/
/backups/
*.sql
*.dump

# Env backup files — luôn coi là chứa secrets. Ops backup .env trước rollout
# (VD .env.bak-20260702-0919 từ llm-abstraction rollout). Không commit.
*.env.bak
.env.bak-*
.env.smoke.bak
.env.*.bak

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.venv-scripts/

# Environment files
.env
*.env.local

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# mTLS artifacts — never commit private keys or CA state
infra/ansible/tls-certs/
infra/vector/certs/
# Real Ansible inventory (may contain internal IPs / hostnames)
infra/ansible/inventory.ini

# OneMCP junction (read-only mirror to D:\Vietnt\Project\onemcp for cross-project context)
/onemcp
