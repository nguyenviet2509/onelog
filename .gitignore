# Runtime data — never commit
infra/data/
infra/.env
infra/litellm/.env.llm
infra/litellm/.env.cost

# Backups & dumps — chứa data user / hashed passwords / secrets snapshot.
# 2026-07-13: postgres-legacy-*.sql (28KB) dumped vào backups/ khi decom PG.
# KHÔNG commit — nếu cần archive, upload offsite (S3/1Password/keepass).
backup/
backups/
*.sql
*.dump

# Env backup files — luôn coi là chứa secrets. Ops backup .env trước rollout
# (VD .env.bak-20260702-0919 từ llm-abstraction rollout). Không commit.
*.env.bak
.env.bak-*
.env.smoke.bak
.env.*.bak

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.venv-scripts/

# Environment files
.env
*.env.local

# Node
node_modules/

# OS
.DS_Store
Thumbs.db

# mTLS artifacts — never commit private keys or CA state
infra/ansible/tls-certs/
infra/vector/certs/
# Real Ansible inventory (may contain internal IPs / hostnames)
infra/ansible/inventory.ini
