# Copy: cp .env.example .env  then fill values
# Production: encrypt with sops + age

# Domain (use app.local for LAN testing, real FQDN for Caddy LE TLS)
APP_DOMAIN=app.local

# Qdrant
QDRANT_API_KEY=changeme_qdrant_long_random

# Postgres
POSTGRES_USER=rag
POSTGRES_PASSWORD=changeme_postgres_long_random

# Redis
REDIS_PASSWORD=changeme_redis_long_random

# LLM — provider-agnostic via LiteLLM. Set LLM_MODEL to <provider>/<model>.
# Examples:
#   anthropic/claude-sonnet-4-5   (premium, best VI quality, prompt caching auto)
#   gemini/gemini-2.5-flash       (default post-benchmark — cheap + fast)
#   openai/gpt-4.1-mini           (balanced fallback)
#   deepseek/deepseek-chat        (cheapest, VI quality weaker)
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_MAX_TOKENS=2048
# Comma-separated fallback chain when primary fails (timeout/5xx/malformed).
# LLM_FALLBACK_MODELS=openai/gpt-4.1-mini,anthropic/claude-sonnet-4-5
LLM_FALLBACK_MODELS=
# Anthropic prompt caching — cuts cost ~65% for repeated system prompt.
# Auto-applied only when LLM_MODEL starts with anthropic/. Safe to leave true.
LLM_ENABLE_PROMPT_CACHE=true

# Provider API keys — set the ones matching your LLM_MODEL / fallback list.
# NOTE: When running with LiteLLM proxy (`--profile llm`), these keys live in
# infra/litellm/.env.llm (chmod 0400 root) so only litellm-proxy reads them.
# The variables below are still needed for the agent service (direct SDK path)
# when NOT using the proxy — leave empty if all traffic routes through proxy.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# LiteLLM proxy (profile: llm) — Phase 2 plan 260701-1544
# Generate: openssl rand -hex 32 | xargs -I{} echo "sk-litellm-{}"
LITELLM_MASTER_KEY=sk-litellm-CHANGE_ME
# NOTE: Postgres backend disabled — Prisma ignores search_path, tables would
# land in public alongside rag-agent. See infra/litellm/config.yaml comment.
# Cost tracking via stdout JSON → VictoriaLogs (V4). If you need per-user
# budget caps + persistent virtual keys, create a DEDICATED DB (not schema):
#   docker compose exec postgres psql -U rag -c "CREATE DATABASE litellm;"
# then uncomment litellm-proxy DATABASE_URL in docker-compose.yml.

# OpenWebUI (profile: chat) — Phase 3 plan 260701-1544
# Session cookie signing. Generate: openssl rand -hex 32
OPENWEBUI_SECRET_KEY=CHANGE_ME_32_CHARS
# LiteLLM key for OpenWebUI. Two options:
#   (a) Reuse LITELLM_MASTER_KEY (MVP, no DB needed — this is the default).
#   (b) Generate a virtual key with budget cap (needs DB backend enabled first).
# For (a): OPENWEBUI_LITELLM_VIRTUAL_KEY=${LITELLM_MASTER_KEY}
OPENWEBUI_LITELLM_VIRTUAL_KEY=${LITELLM_MASTER_KEY}
# Bootstrap admin — set on first boot ONLY. After first login, comment out and
# restart openwebui so DB-managed users take over (RT-F2 race prevention).
# OPENWEBUI_BOOTSTRAP_ADMIN_EMAIL=admin@onelog.local
# OPENWEBUI_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG

# MCP token dedicated to OpenWebUI (RT-F3). Add to MCP_BEARER_TOKENS below as
# `openwebui:<this_token>` — revoke independently from agent / Claude Desktop.
MCP_TOKEN_OPENWEBUI=sk-mcp-openwebui-CHANGE_ME

# mcpo bridge API key — protects the MCP-to-OpenAPI proxy exposed at
# http://mcpo:8080. Register in OpenWebUI as Bearer for each tool endpoint.
MCPO_API_KEY=sk-mcpo-CHANGE_ME

# Legacy — still honored for back-compat if LLM_MODEL uses default.
# ANTHROPIC_MODEL=claude-sonnet-4-5

OPENAI_EMBED_MODEL=text-embedding-3-small
# Embedding overrides for indexer (defaults match OPENAI_* above).
# EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1
# Set EMBED_MOCK=true to use deterministic hash vectors (offline / dev).
EMBED_MOCK=false
# Set LLM_MOCK=true for in-process canned responses (no API key needed).
# Useful for pre-key dev + deterministic tests of the agent loop.
LLM_MOCK=false
# Corp proxy for outbound LLM/embedding (LiteLLM picks up HTTPS_PROXY env).
# HTTPS_PROXY=http://proxy.corp:8080

# Telegram (alert push only, Phase 06)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# IP allow list for Caddy (comma-separated CIDR) — until auth plug
# Example LAN: 10.0.0.0/8,192.168.0.0/16
ADMIN_ALLOW_CIDR=192.168.122.0/24

# VictoriaLogs retention (PoC = 7d for small disk; production = 30d-90d)
VL_RETENTION=7d

# MCP Bearer tokens — one entry per ops engineer for both mcp-vl and mcp-semantic.
# Format: user1:sk-aaa,user2:sk-bbb,...
# Generate with: infra/scripts/gen-mcp-tokens.sh alice bob carol dave eve
# Empty + MCP_ALLOW_ANON unset = fail-closed (every request denied at /auth/verify).
MCP_BEARER_TOKENS=

# Set to true ONLY for local dev when MCP_BEARER_TOKENS is empty. In production
# leave unset/false so a forgotten token env doesn't silently allow everyone.
MCP_ALLOW_ANON=false

# Public base URL used in clickable VMUI deep links emitted by tool responses.
# Set to the Caddy entry users actually reach (LAN: http://app.local, prod: https://...).
VMUI_BASE_URL=http://app.local

# Cost Dashboard (profile: dashboard) — Phase 260709-1143
# ADMIN_STRICT_CIDR: SPACE-separated CIDR of admin machines only — NOT the full LAN.
#   Example: two machines → "10.0.14.3/32 10.60.1.97/32"
#   Caddy `remote_ip` matcher requires space-separated (not comma).
# GRAFANA_ADMIN_PASSWORD: Bootstrap Grafana admin password.
#   Generate: openssl rand -base64 24
#   Change via Grafana UI immediately after first login.
ADMIN_STRICT_CIDR=192.168.122.10/32 192.168.122.11/32
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG

# Phase 04 · LLM cost alert thresholds (used in vmalert rules — MVP hardcoded, tune after Phase A)
COST_ALERT_DEEPSEEK_BALANCE_MIN=5
COST_ALERT_OPENAI_DAILY_MAX=3
COST_ALERT_ANTHROPIC_MONTHLY_SOFT=14
COST_ALERT_FALLBACK_DAILY_MAX=20
COST_ALERT_USER_DAILY_MAX=2
