  "description": "OneLog LLM Cost Dashboard — 5 ops · 4 providers. Data from LiteLLM json_logs via VictoriaLogs.\n\nTODO (Phase 02 verification): Confirm exact field name for request cost. LiteLLM default is `response_cost`; some deployments emit `spend` or nested `metadata.usage.cost`. Run: curl -s 'http://localhost:9428/select/logsql/query' --data-urlencode 'query=service:litellm_cost event:litellm_cost _time:5m' | jq 'keys' to verify before using panels.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "KPI",
      "type": "row"
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Cost — last 30d",
      "description": "Tổng cost 30 ngày gần nhất. VictoriaLogs không hỗ trợ _time:month (calendar month), dùng rolling 30d.",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:30d\n  | stats sum(response_cost) as total",
          "legendFormat": "total",
          "queryType": "stats",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Cost — today",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:1d\n  | stats sum(response_cost) as today",
          "legendFormat": "today",
          "queryType": "stats",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Tokens — 24h",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:24h\n  | stats sum(prompt_tokens) as tin,\n          sum(completion_tokens) as tout",
          "legendFormat": "__auto",
          "queryType": "stats",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "description": "Cache hit rate for Anthropic/Claude models. High cache hit (>60%) cuts cost significantly via prompt caching.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "green", "value": 60 }
            ]
          },
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Cache hit % — Anthropic 24h",
      "type": "stat",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:24h model:claude*\n  | stats sum(cache_read_input_tokens) as cached,\n          sum(prompt_tokens) as total\n  | math (cached / total) * 100 as hit_pct",
          "legendFormat": "cache hit %",
          "queryType": "stats",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "description": "Number of fallback events in the last 24h. High fallback count indicates primary provider instability.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short",
          "decimals": 0
