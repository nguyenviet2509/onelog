          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:7d\n  | stats by (model) sum(response_cost) as cost\n  | sort by (cost) desc",
          "legendFormat": "{{model}}",
          "queryType": "stats",
          "refId": "A"
        }
      ]
    },
