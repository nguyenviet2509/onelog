      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:30d\n  | stats by (_time:1d, model) sum(response_cost) as cost",
          "legendFormat": "{{model}}",
          "queryType": "stats",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
