            "matcher": { "id": "byName", "options": "model" },
            "properties": [{ "id": "displayName", "value": "Primary model" }]
          },
          {
            "matcher": { "id": "byName", "options": "fallback_model" },
            "properties": [{ "id": "displayName", "value": "Fallback model" }]
