        "valueMode": "color"
      },
      "title": "Per-user cost 7d",
      "type": "bargauge",
      "targets": [
        {
          "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
          "expr": "service:litellm_cost event:litellm_cost _time:7d user_api_key_alias:*\n  | stats by (user_api_key_alias)\n          sum(response_cost) as spent,\n          count() as reqs\n  | sort by (spent) desc",
          "legendFormat": "{{user_api_key_alias}}",
