{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "title": "OneLog Pipeline Health",
  "uid": "onelog-pipeline-health",
  "schemaVersion": 39,
  "tags": ["onelog", "self-monitoring"],
  "time": {"from": "now-3h", "to": "now"},
  "refresh": "30s",
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "Ingest rate (VL, bytes/s)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "rate(vl_bytes_ingested_total[1m])",
          "legendFormat": "{{component}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Indexer NATS lag (seconds) + batches/s",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "indexer_ingest_lag_seconds or vector(0)",
          "legendFormat": "lag (s)",
          "refId": "A"
        },
        {
          "expr": "rate(indexer_batches_processed_total[1m])",
          "legendFormat": "batches/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "Qdrant collection points (log_templates)",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "collection_points{id=\"log_templates\"} or vector(0)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "VL storage (GB)",
      "type": "stat",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 6},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "vl_data_size_bytes / 1024 / 1024 / 1024",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "GB", "decimals": 2}}
    },
    {
      "id": 5,
      "title": "Component up",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {"expr": "up{job=~\"onelog-.*\"}", "legendFormat": "{{job}}", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
          ]
        }
      }
    },
    {
      "id": 6,
      "title": "Recent alerts (vmalert)",
      "type": "table",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {"expr": "ALERTS{alertstate=\"firing\"}", "instant": true, "refId": "A"}
      ]
    },
    {
      "id": 7,
      "title": "Host CPU %",
      "type": "stat",
      "gridPos": {"x": 0, "y": 22, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {"expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"onelog-host\", mode=\"idle\"}[1m])) * 100)", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}},
      "options": {"graphMode": "area"},
      "links": [{"title": "Drill-down → OneLog VPS Host", "url": "/d/onelog-vps-host/onelog-vps-host"}]
    },
    {
      "id": 8,
      "title": "Host RAM used %",
      "type": "stat",
      "gridPos": {"x": 8, "y": 22, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {"expr": "(1 - node_memory_MemAvailable_bytes{job=\"onelog-host\"} / node_memory_MemTotal_bytes{job=\"onelog-host\"}) * 100", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}},
      "options": {"graphMode": "area"},
      "links": [{"title": "Drill-down → OneLog VPS Host", "url": "/d/onelog-vps-host/onelog-vps-host"}]
    },
    {
      "id": 9,
      "title": "Host network (rx+tx bytes/s)",
      "type": "stat",
      "gridPos": {"x": 16, "y": 22, "w": 8, "h": 6},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {"expr": "sum(rate(node_network_receive_bytes_total{job=\"onelog-host\", device!~\"lo|docker.*|veth.*|br-.*\"}[1m])) + sum(rate(node_network_transmit_bytes_total{job=\"onelog-host\", device!~\"lo|docker.*|veth.*|br-.*\"}[1m]))", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}},
      "options": {"graphMode": "area"},
      "links": [{"title": "Drill-down → OneLog VPS Host", "url": "/d/onelog-vps-host/onelog-vps-host"}]
    }
  ]
}
