{
  "annotations": {"list": []},
  "editable": false,
  "graphTooltip": 1,
  "title": "OneLog VPS Host",
  "uid": "onelog-vps-host",
  "schemaVersion": 39,
  "tags": ["onelog", "host", "self-monitoring"],
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s",
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "title": "CPU % (by mode)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{job=\"onelog-host\"}[1m])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "custom": {"stacking": {"mode": "normal"}}}}
    },
    {
      "id": 2,
      "title": "Load average",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {"expr": "node_load1{job=\"onelog-host\"}", "legendFormat": "1m", "refId": "A"},
        {"expr": "node_load5{job=\"onelog-host\"}", "legendFormat": "5m", "refId": "B"},
        {"expr": "node_load15{job=\"onelog-host\"}", "legendFormat": "15m", "refId": "C"}
      ]
    },
    {
      "id": 3,
      "title": "Memory (used / cached / free)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{job=\"onelog-host\"} - node_memory_MemFree_bytes{job=\"onelog-host\"} - node_memory_Buffers_bytes{job=\"onelog-host\"} - node_memory_Cached_bytes{job=\"onelog-host\"}",
          "legendFormat": "used",
          "refId": "A"
        },
        {
          "expr": "node_memory_Cached_bytes{job=\"onelog-host\"} + node_memory_Buffers_bytes{job=\"onelog-host\"}",
          "legendFormat": "cached+buffers",
          "refId": "B"
        },
        {
          "expr": "node_memory_MemFree_bytes{job=\"onelog-host\"}",
          "legendFormat": "free",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"stacking": {"mode": "normal"}}}}
    },
    {
      "id": 4,
      "title": "Swap used",
      "type": "stat",
      "gridPos": {"x": 12, "y": 8, "w": 6, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "node_memory_SwapTotal_bytes{job=\"onelog-host\"} - node_memory_SwapFree_bytes{job=\"onelog-host\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 5,
      "title": "Root disk used %",
      "type": "stat",
      "gridPos": {"x": 18, "y": 8, "w": 6, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{job=\"onelog-host\", mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"onelog-host\", mountpoint=\"/\"} * 100)",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}}
    },
    {
      "id": 6,
      "title": "Network throughput (rx / tx bytes/s per interface)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{job=\"onelog-host\", device!~\"lo|docker.*|veth.*|br-.*\"}[1m])",
          "legendFormat": "rx {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{job=\"onelog-host\", device!~\"lo|docker.*|veth.*|br-.*\"}[1m])",
          "legendFormat": "tx {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "id": 7,
      "title": "Disk I/O bytes/s (read / write per device)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "victoriametrics"},
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"onelog-host\", device!~\"loop.*|dm-.*\"}[1m])",
          "legendFormat": "read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"onelog-host\", device!~\"loop.*|dm-.*\"}[1m])",
          "legendFormat": "write {{device}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    }
  ]
}
