# Admin API keys for provider cost polling.
# Copy to .env.cost, fill real values, then: chmod 0400 .env.cost
#
# IMPORTANT: Create NEW admin/org-level keys — NOT the same as project keys in .env.llm.
# These keys need read-only cost/usage scopes only:
#   OpenAI:    platform.openai.com → Organization → Admin keys → costs.read + usage.read
#   Anthropic: console.anthropic.com → Organization Settings → API Keys → Admin Key
#   DeepSeek:  reuse existing DEEPSEEK_API_KEY from .env.llm (no separate admin key needed)
#
# Security:
#   chmod 0400 /root/onelog/infra/litellm/.env.cost   (root read-only)
#   chown root:root /root/onelog/infra/litellm/.env.cost
#   NEVER commit the real .env.cost — it is in .gitignore.
#   Rotate every 90 days (see docs/runbook-rotate-admin-keys.md, Phase 05).

OPENAI_ADMIN_KEY=sk-admin-REPLACE_ME
ANTHROPIC_ADMIN_KEY=sk-ant-admin-REPLACE_ME
DEEPSEEK_API_KEY=sk-REPLACE_ME_or_source_from_env_llm
