# LiteLLM provider API keys — DO NOT commit real values.
#
# Deploy setup (RT-F1 blast-radius separation):
#   sudo install -m 0400 -o root -g root .env.llm.example .env.llm
#   sudo $EDITOR .env.llm
#
# Only the litellm-proxy container reads this file (via compose env_file).
# Rest of the stack keeps using infra/.env — provider keys never leak into
# agent/vector/postgres environments.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
