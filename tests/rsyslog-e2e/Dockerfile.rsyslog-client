# Minimal rsyslog client container for OneLog E2E test.
# Alpine + rsyslog (with TCP output module). Reads from /dev/log via imuxsock,
# forwards JSON to OneLog Vector on host:6515.
FROM alpine:3.19

RUN apk add --no-cache rsyslog logger ca-certificates && \
    mkdir -p /var/spool/rsyslog && \
    chmod 700 /var/spool/rsyslog

COPY rsyslog.conf /etc/rsyslog.conf

# Foreground; output to stderr for `docker logs`
CMD ["rsyslogd", "-n", "-f", "/etc/rsyslog.conf", "-i", "/tmp/rsyslogd.pid"]
