# Database
DATABASE_URL=postgres://user:password@localhost:5432/onelog

# DeepSeek LLM (KB summarizer)
DEEPSEEK_API_KEY=
KB_SUMMARIZE_MODEL=deepseek-chat
# Set to "true" to skip real LLM calls and return a fixed mock draft (dev/CI)
KB_LLM_MOCK=false

# OpenAI-compat embeddings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
KB_QDRANT_COLLECTION=kb_resolved

# KB thresholds
KB_DEDUP_THRESHOLD=0.9
KB_SNAP_THRESHOLD=0.85

# Backfill rate (conversations per minute)
KB_BACKFILL_RPM=5

# Agent backend
AGENT_URL=http://agent:8080
