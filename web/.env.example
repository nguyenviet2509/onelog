# ──────────────────────────────────────────────────────────────────────────────
# OneLog Web — environment variables
# Copy to .env.local for local development. Never commit .env.local.
# ──────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgres://user:password@localhost:5432/rag

# ── KB Phase 1 — OpenWebUI integration ───────────────────────────────────────

# OpenWebUI base URL (inside docker network: http://openwebui:8080)
# Used to verify chat ownership + fetch messages via OpenWebUI REST API.
OPENWEBUI_URL=http://openwebui:8080

# Admin API key for backfill script (get from OpenWebUI Admin → API Keys).
# Not required at runtime — only needed when running kb-backfill.ts.
OPENWEBUI_ADMIN_API_KEY=

# ── LLM summarizer (DeepSeek — OpenAI-compat) ────────────────────────────────
DEEPSEEK_API_KEY=
KB_SUMMARIZE_MODEL=deepseek-chat
# Set to "true" to skip real LLM calls and return a fixed mock draft (dev/CI)
KB_LLM_MOCK=false

# ── Embeddings (OpenAI-compat) ────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EMBED_MODEL=text-embedding-3-small
# Set to "true" to use deterministic sha256 mock vectors (dev/CI, no API key needed)
EMBED_MOCK=false

# ── Qdrant vector store ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
KB_QDRANT_COLLECTION=kb_resolved

# ── KB tuning ─────────────────────────────────────────────────────────────────
# Cosine similarity threshold above which a candidate is flagged as duplicate
KB_DEDUP_THRESHOLD=0.9
# Taxonomy snap threshold — existing label reused if similarity >= this value
KB_SNAP_THRESHOLD=0.85
# How long a draft stays valid (minutes). Member must review within this window.
KB_DRAFT_TTL_MINUTES=30
# Max KB summarize requests per user per day (drafts + committed entries)
KB_RATE_LIMIT_PER_USER_DAY=20

# ── Review page public URL ────────────────────────────────────────────────────
# Base URL returned in the review link sent back to OpenWebUI Function.
# Must be reachable by the member's browser (not internal docker hostname).
KB_WEB_PUBLIC_URL=http://localhost:3000

# ── Internal cron token ───────────────────────────────────────────────────────
# Protects POST /api/kb/internal/cleanup-drafts from unauthorized calls.
# Generate: openssl rand -hex 32
# Used by external scheduler (systemd timer / cron) to trigger hourly GC:
#   curl -s -X POST http://web:3000/api/kb/internal/cleanup-drafts \
#        -H "x-internal-token: $INTERNAL_CRON_TOKEN"
# Note: opportunistic cleanup also runs on every /api/kb/summarize call as
# a safety net — external cron is optional but recommended for consistency.
INTERNAL_CRON_TOKEN=
